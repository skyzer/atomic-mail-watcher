# Atomic Mail Watcher notification configuration
# Copy this file to .env.agent-a, .env.agent-b, etc. Do not commit real .env.* files.
# Atomic Mail API credentials normally live in each service's mounted credentials file:
#   data/agent-a/credentials.json
#   data/agent-b/credentials.json

# Optional: instead of /data/credentials.json, a service can receive Atomic Mail creds here.
# ATOMICMAIL_INBOX_ID=agent-a@atomicmail.ai
# ATOMICMAIL_API_KEY=am_...
# ATOMICMAIL_AUTH_URL=https://auth.atomicmail.ai
# ATOMICMAIL_API_URL=https://api.atomicmail.ai

# Telegram notifications
# TELEGRAM_BOT_TOKEN=123456:abc
# TELEGRAM_CHAT_ID=123456789

# Generic webhook notifications
# WEBHOOK_URL=https://example.com/atomicmail-webhook
# WEBHOOK_BEARER_TOKEN=optional-shared-secret

# Runtime paths inside the container
DATA_DIR=/data
